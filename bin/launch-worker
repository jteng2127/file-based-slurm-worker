#!/usr/bin/env bash

{
    set -u

    # Args
    TASK_DIR=${1%/}
    MAX_IDLE=${2:--1}
    ACCEPT_TASK_TIME_SECOND_LIMIT=${3:--1}
    LOG_SYSTEM_METRICS=${4:-0}
    MAX_CONSECUTIVE_FAILS=${5:--1}

    # Define directory constants
    PENDING_DIR=${TASK_DIR}/1_pending
    RUNNING_DIR=${TASK_DIR}/2_running
    DONE_DIR=${TASK_DIR}/3_done
    FAILED_DIR=${TASK_DIR}/4_failed
    TASK_LOGS_DIR=${TASK_DIR}/5_task_logs
    WORKER_STATUS_DIR=${TASK_DIR}/7_worker_status

    if [ ! -d "$PENDING_DIR" ]; then
        echo "Task directory not found: $PENDING_DIR"
        exit 1
    fi

    mkdir -p "$RUNNING_DIR" "$DONE_DIR" "$FAILED_DIR" "$TASK_LOGS_DIR" "$WORKER_STATUS_DIR"

    # Determine Worker ID (Slurm or PID)
    if [ -z "${SLURM_JOB_ID:-}" ] || [ -z "${SLURM_STEP_ID:-}" ]; then
        echo "Not running in a Slurm job. Using PID as worker ID."
        WORKER_ID=$$
    else
        echo "Running in a Slurm job. Using SLURM_JOB_ID and SLURM_STEP_ID as worker ID."
        WORKER_ID=${SLURM_JOB_ID}.${SLURM_STEP_ID}
    fi

    # Helper function for logging
    log() { echo "$(date '+%Y-%m-%d %H:%M:%S') [Worker ${WORKER_ID}] $1"; }

    # Helper function to update worker status file
    update_status() { echo "$(date '+%Y-%m-%d %H:%M:%S') $1" > "$WORKER_STATUS_DIR/$WORKER_ID"; }

    # Helper function to recursively kill process tree
    kill_tree() {
        local pid=$1
        for child in $(pgrep -P "$pid" 2>/dev/null); do
            kill_tree "$child"
        done
        kill "$pid" 2>/dev/null
    }

    # Cleanup function to handle termination signals when the worker is killed
    trap_cleanup() {
        log "Shutdown signal received."
        cleanup
    }

    cleanup() {
        if [ -n "${SUB_PID:-}" ]; then
            kill_tree "$SUB_PID"
            wait "$SUB_PID" 2>/dev/null
            log "Sub-process $SUB_PID terminated."
        fi
        if [ -n "${CURRENT_FILE:-}" ]; then
            mv "$RUNNING_DIR/$CURRENT_FILE" "$PENDING_DIR/" 2>/dev/null
            log "Recovered $CURRENT_FILE back to $PENDING_DIR."
        fi
        rm -f "$WORKER_STATUS_DIR/$WORKER_ID"
        log "Exiting."
        exit 0
    }

    trap trap_cleanup SIGINT SIGTERM

    # Main loop
    IDLE_COUNT=0
    JOB_COUNT=0
    FAILED_TASKS=()
    SUB_PID=""
    CURRENT_FILE=""
    WORKER_START_TIME=$(date +%s)
    log "Started worker in $TASK_DIR"
    update_status "STARTED"

    while [ "$MAX_IDLE" -lt 0 ] || [ $IDLE_COUNT -lt $MAX_IDLE ]; do
        if [ "$ACCEPT_TASK_TIME_SECOND_LIMIT" -gt 0 ]; then
            CURRENT_TIME=$(date +%s)
            ELAPSED_TIME=$(( CURRENT_TIME - WORKER_START_TIME ))
            if [ "$ELAPSED_TIME" -gt "$ACCEPT_TASK_TIME_SECOND_LIMIT" ]; then
                log "Time limit reached (Elapsed: ${ELAPSED_TIME}s, Limit: ${ACCEPT_TASK_TIME_SECOND_LIMIT}s). Stopping task acceptance."
                break
            fi
        fi

        SCRIPT_PATH=$(ls "$PENDING_DIR"/*.sh 2>/dev/null | head -n 1)

        if [ -n "$SCRIPT_PATH" ]; then
            FILENAME=$(basename "$SCRIPT_PATH")
            if mv "$PENDING_DIR/$FILENAME" "$RUNNING_DIR/$FILENAME" 2>/dev/null; then
                IDLE_COUNT=0
                CURRENT_FILE="$FILENAME"
                TASK_LOG="$TASK_LOGS_DIR/${FILENAME%.sh}-${WORKER_ID}.${JOB_COUNT}.log"
                log "Processing: $FILENAME, log: $TASK_LOG"
                update_status "RUNNING $FILENAME"

                # Log system metrics before executing the task
                if [ "$LOG_SYSTEM_METRICS" -eq 1 ]; then
                    echo "================ System Metrics ================" >> "$TASK_LOG"
                    echo "Hostname: $(hostname)" >> "$TASK_LOG"
                    if command -v nvidia-smi &> /dev/null; then
                        echo "--- GPU Status ---" >> "$TASK_LOG"
                        nvidia-smi >> "$TASK_LOG" 2>&1
                    else
                        echo "GPU: nvidia-smi not found." >> "$TASK_LOG"
                    fi
                    echo "--- CPU/Memory Status ---" >> "$TASK_LOG"
                    top -bn1 -1 | grep "^%Cpu" | sed 's/  *%Cpu/\n%Cpu/g' | awk -F'[: ,]+' '/^%Cpu/ {printf "%s: %s %s, %s %s\n", $1, $2, $3, $4, $5}' >> "$TASK_LOG" 2>&1
                    free -h >> "$TASK_LOG" 2>&1
                    cat /proc/meminfo | grep -E '(Commit|Mem)' >> "$TASK_LOG" 2>&1
                    echo "--- Top Processes by Memory ---" >> "$TASK_LOG"
                    ps -eo pcpu,pmem,args --sort=-pmem | head -n 4 >> "$TASK_LOG" 2>&1
                    echo "--- Top Processes by CPU ---" >> "$TASK_LOG"
                    ps -eo pcpu,pmem,args --sort=-pcpu | head -n 4 >> "$TASK_LOG" 2>&1
                    echo "=================================================" >> "$TASK_LOG"
                    echo "" >> "$TASK_LOG"
                fi

                # Execute the task
                WORKER_JOB_ID="${WORKER_ID}.${JOB_COUNT}" bash "$RUNNING_DIR/$FILENAME" >> "$TASK_LOG" 2>&1 &
                SUB_PID=$!

                # Wait and monitor for file deletion
                while kill -0 "$SUB_PID" 2>/dev/null; do
                    if [ ! -f "$RUNNING_DIR/$FILENAME" ]; then
                        log "Task file $FILENAME moved out of $RUNNING_DIR. Killing task $SUB_PID."
                        kill_tree "$SUB_PID"
                        break
                    fi
                    if [ ! -f "$WORKER_STATUS_DIR/$WORKER_ID" ]; then
                        log "Status file removed. Sending SIGTERM to self."
                        kill -SIGTERM $$
                    fi
                    sleep 10
                done
                wait "$SUB_PID" 2>/dev/null
                EXIT_CODE=$?

                if [ -f "$RUNNING_DIR/$FILENAME" ]; then
                    if [ $EXIT_CODE -eq 0 ]; then
                        mv "$RUNNING_DIR/$FILENAME" "$DONE_DIR/"
                        log "Success: $FILENAME"
                        FAILED_TASKS=()
                    else
                        FAILED_TASKS+=("$FILENAME")
                        mv "$RUNNING_DIR/$FILENAME" "$FAILED_DIR/"
                        log "Failed: $FILENAME (Exit Code: $EXIT_CODE)"

                        if [ "$MAX_CONSECUTIVE_FAILS" -gt 0 ] && [ "${#FAILED_TASKS[@]}" -ge "$MAX_CONSECUTIVE_FAILS" ]; then
                            log "Critical Error: Max consecutive failures ($MAX_CONSECUTIVE_FAILS) reached."
                            log "Recovering failed tasks to pending: ${FAILED_TASKS[*]}"
                            for failed_task in "${FAILED_TASKS[@]}"; do
                                mv "$FAILED_DIR/$failed_task" "$PENDING_DIR/" 2>/dev/null || true
                            done
                            CURRENT_FILE=""
                            SUB_PID=""
                            cleanup
                        fi
                    fi
                else
                    log "Aborted: $FILENAME (moved out of $RUNNING_DIR)"
                fi
                JOB_COUNT=$((JOB_COUNT + 1))
                CURRENT_FILE=""
                SUB_PID=""
            fi
        else
            # Increment idle counter and wait
            if [ ! -f "$WORKER_STATUS_DIR/$WORKER_ID" ]; then
                log "Status file removed. Sending SIGTERM to self."
                kill -SIGTERM $$
            fi
            if [ "$MAX_IDLE" -lt 0 ]; then
                update_status "IDLE (Forever)"
            else
                update_status "IDLE (${IDLE_COUNT}/${MAX_IDLE})"
            fi
            ((IDLE_COUNT+=10))
            sleep 10
        fi
    done

    log "Idle timeout. Exiting."
    cleanup
}
